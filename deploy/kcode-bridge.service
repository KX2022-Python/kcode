[Unit]
Description=Kcode Bridge - AI Agent Multi-Channel Service
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
Restart=always
RestartSec=5

# Load environment variables from file
EnvironmentFile=-/etc/kcode/bridge.env

# Execute the bridge command
ExecStart=/usr/local/bin/kcode bridge

# Logging
StandardOutput=journal
StandardError=journal

# Security
ProtectSystem=strict
ReadWritePaths=/home/ubuntu/.kcode

[Install]
WantedBy=multi-user.target
